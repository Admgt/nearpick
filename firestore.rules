rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isInterestCountUpdate() {
      let before = resource.data.interestCount;
      let after = request.resource.data.interestCount;
      return isSignedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['interestCount'])
        && before is int
        && after is int
        && after >= 0
        && (after == before + 1 || after == before - 1);
    }

    function hasValidProductImage(productId) {
      return request.resource.data.hasImage == true
        ? request.resource.data.keys().hasAll(['imagePath', 'imageUrl'])
          && request.resource.data.imagePath is string
          && request.resource.data.imagePath.matches(
            '^products/' + request.auth.uid + '/' + productId + '/[^/]+$'
          )
          && request.resource.data.imageUrl is string
        : request.resource.data.hasImage == false
          && !request.resource.data.keys().hasAny(['imagePath', 'imageUrl']);
    }

    function hasValidPricingRecommendation() {
      return !request.resource.data.keys().hasAny(['pricingRecommendation'])
        || (
          request.resource.data.pricingRecommendation is map
          && request.resource.data.pricingRecommendation.keys().hasOnly([
            'activeCategoryOffers',
            'averageDiscountPercent',
            'demandLevel',
            'demandScore',
            'discountPercent',
            'dismissals7d',
            'expectedReservations24h',
            'generatedAt',
            'interests7d',
            'maximumSuggestedPrice',
            'minimumSuggestedPrice',
            'recommendedPrice',
            'views7d',
          ])
          && request.resource.data.pricingRecommendation.recommendedPrice is int
          && request.resource.data.pricingRecommendation.recommendedPrice > 0
          && request.resource.data.pricingRecommendation.minimumSuggestedPrice is int
          && request.resource.data.pricingRecommendation.minimumSuggestedPrice > 0
          && request.resource.data.pricingRecommendation.maximumSuggestedPrice is int
          && request.resource.data.pricingRecommendation.maximumSuggestedPrice > 0
          && request.resource.data.pricingRecommendation.discountPercent is int
          && request.resource.data.pricingRecommendation.discountPercent >= 0
          && request.resource.data.pricingRecommendation.discountPercent <= 100
          && request.resource.data.pricingRecommendation.demandScore is number
          && request.resource.data.pricingRecommendation.demandScore >= 0
          && request.resource.data.pricingRecommendation.demandScore <= 1
          && request.resource.data.pricingRecommendation.demandLevel is string
          && request.resource.data.pricingRecommendation.expectedReservations24h is int
          && request.resource.data.pricingRecommendation.expectedReservations24h >= 0
          && request.resource.data.pricingRecommendation.views7d is int
          && request.resource.data.pricingRecommendation.views7d >= 0
          && request.resource.data.pricingRecommendation.interests7d is int
          && request.resource.data.pricingRecommendation.interests7d >= 0
          && request.resource.data.pricingRecommendation.dismissals7d is int
          && request.resource.data.pricingRecommendation.dismissals7d >= 0
          && request.resource.data.pricingRecommendation.activeCategoryOffers is int
          && request.resource.data.pricingRecommendation.activeCategoryOffers >= 0
          && request.resource.data.pricingRecommendation.averageDiscountPercent is int
          && request.resource.data.pricingRecommendation.averageDiscountPercent >= 0
          && request.resource.data.pricingRecommendation.averageDiscountPercent <= 100
          && request.resource.data.pricingRecommendation.generatedAt is timestamp
        );
    }

    function isValidProductCreate(productId) {
      return isSignedIn()
        && request.resource.data.keys().hasOnly([
          'archivedAt',
          'category',
          'createdAt',
          'deletedAt',
          'discountedPrice',
          'expiresAt',
          'hasImage',
          'imagePath',
          'imageUrl',
          'interestCount',
          'isDeleted',
          'location',
          'name',
          'originalPrice',
          'ownerId',
          'pickupEndAt',
          'pickupStartAt',
          'pricingRecommendation',
          'quantity',
          'quantityAvailable',
          'status',
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.category is string
        && request.resource.data.originalPrice is int
        && request.resource.data.originalPrice >= 0
        && request.resource.data.discountedPrice is int
        && request.resource.data.discountedPrice >= 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.quantityAvailable is int
        && request.resource.data.quantityAvailable == request.resource.data.quantity
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.pickupStartAt is timestamp
        && request.resource.data.pickupEndAt is timestamp
        && request.resource.data.pickupEndAt > request.resource.data.pickupStartAt
        && request.resource.data.createdAt is timestamp
        && request.resource.data.interestCount == 0
        && request.resource.data.status == 'active'
        && request.resource.data.isDeleted == false
        && request.resource.data.archivedAt == null
        && request.resource.data.deletedAt == null
        && hasValidProductImage(productId)
        && hasValidPricingRecommendation();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isValidProductCreate(productId);
      allow update: if isInterestCountUpdate();
      allow delete: if false;
    }

    match /reservations/{reservationId} {
      allow create: if false;
      allow read: if isSignedIn()
        && (resource.data.buyerId == request.auth.uid
          || resource.data.merchantId == request.auth.uid);
      allow update: if false;
      allow delete: if false;
    }

    match /merchantStats/{merchantId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /interests/{interestId} {
      allow read: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || interestId.matches('^' + request.auth.uid + '_.*')
        );
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || interestId.matches('^' + request.auth.uid + '_.*')
        )
        && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || interestId.matches('^' + request.auth.uid + '_.*')
        );
    }

    match /userInteractions/{interactionId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
          || resource.data.userId == request.auth.uid);
    }

    match /userImplicitPrefs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /userNegativePrefs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
