rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.admin == true
        && (!hasUserProfile()
          || currentUserData().accountStatus == null
          || currentUserData().accountStatus == 'active');
    }

    function isActiveUser() {
      return hasUserProfile()
        && (currentUserData().accountStatus == null
          || currentUserData().accountStatus == 'active');
    }

    function isActiveMerchant() {
      return isActiveUser() && currentUserData().role == 'merchant';
    }

    function canReadProtectedData() {
      return isAdmin() || isActiveUser();
    }

    function hasValidUserDocKeys() {
      return request.resource.data.keys().hasOnly([
        'accountStatus',
        'companyLocation',
        'companyName',
        'createdAt',
        'displayName',
        'email',
        'favoriteCategories',
        'homeLocation',
        'homeLocationCityId',
        'homeLocationMode',
        'preferredRadiusKm',
        'role',
        'statusUpdatedAt',
        'statusUpdatedBy',
      ]);
    }

    function isValidUserCreate() {
      return isSignedIn()
        && hasValidUserDocKeys()
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.role in ['consumer', 'merchant']
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.createdAt is timestamp
        && (!request.resource.data.keys().hasAny(['companyName'])
          || request.resource.data.companyName is string);
    }

    function isValidUserSelfUpdate(userId) {
      return isActiveUser()
        && request.auth.uid == userId
        && hasValidUserDocKeys()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'companyLocation',
          'companyName',
          'displayName',
          'favoriteCategories',
          'homeLocation',
          'homeLocationCityId',
          'homeLocationMode',
          'preferredRadiusKm',
        ])
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.accountStatus == resource.data.accountStatus
        && request.resource.data.createdAt == resource.data.createdAt
        && (!request.resource.data.keys().hasAny(['statusUpdatedAt'])
          || request.resource.data.statusUpdatedAt == resource.data.statusUpdatedAt)
        && (!request.resource.data.keys().hasAny(['statusUpdatedBy'])
          || request.resource.data.statusUpdatedBy == resource.data.statusUpdatedBy)
        && request.resource.data.displayName is string
        && (!request.resource.data.keys().hasAny(['companyName'])
          || request.resource.data.companyName is string);
    }

    function isValidAdminMessageReadUpdate(userId) {
      return isActiveUser()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'readAt',
        ])
        && resource.data.readAt == null
        && request.resource.data.readAt is timestamp;
    }

    function isInterestCountUpdate() {
      let before = resource.data.interestCount;
      let after = request.resource.data.interestCount;
      return canReadProtectedData()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['interestCount'])
        && before is int
        && after is int
        && after >= 0
        && (after == before + 1 || after == before - 1);
    }

    function hasValidProductImage(productId) {
      return request.resource.data.hasImage == true
        ? request.resource.data.keys().hasAll(['imagePath', 'imageUrl'])
          && request.resource.data.imagePath is string
          && request.resource.data.imagePath.matches(
            '^products/' + request.auth.uid + '/' + productId + '/[^/]+$'
          )
          && request.resource.data.imageUrl is string
        : request.resource.data.hasImage == false
          && !request.resource.data.keys().hasAny(['imagePath', 'imageUrl']);
    }

    function hasValidPricingRecommendation() {
      return !request.resource.data.keys().hasAny(['pricingRecommendation'])
        || (
          request.resource.data.pricingRecommendation is map
          && request.resource.data.pricingRecommendation.keys().hasOnly([
            'activeCategoryOffers',
            'averageDiscountPercent',
            'demandLevel',
            'demandScore',
            'discountPercent',
            'dismissals7d',
            'expectedReservations24h',
            'generatedAt',
            'interests7d',
            'maximumSuggestedPrice',
            'minimumSuggestedPrice',
            'recommendedPrice',
            'views7d',
          ])
          && request.resource.data.pricingRecommendation.recommendedPrice is int
          && request.resource.data.pricingRecommendation.recommendedPrice > 0
          && request.resource.data.pricingRecommendation.minimumSuggestedPrice is int
          && request.resource.data.pricingRecommendation.minimumSuggestedPrice > 0
          && request.resource.data.pricingRecommendation.maximumSuggestedPrice is int
          && request.resource.data.pricingRecommendation.maximumSuggestedPrice > 0
          && request.resource.data.pricingRecommendation.discountPercent is int
          && request.resource.data.pricingRecommendation.discountPercent >= 0
          && request.resource.data.pricingRecommendation.discountPercent <= 100
          && request.resource.data.pricingRecommendation.demandScore is number
          && request.resource.data.pricingRecommendation.demandScore >= 0
          && request.resource.data.pricingRecommendation.demandScore <= 1
          && request.resource.data.pricingRecommendation.demandLevel is string
          && request.resource.data.pricingRecommendation.expectedReservations24h is int
          && request.resource.data.pricingRecommendation.expectedReservations24h >= 0
          && request.resource.data.pricingRecommendation.views7d is int
          && request.resource.data.pricingRecommendation.views7d >= 0
          && request.resource.data.pricingRecommendation.interests7d is int
          && request.resource.data.pricingRecommendation.interests7d >= 0
          && request.resource.data.pricingRecommendation.dismissals7d is int
          && request.resource.data.pricingRecommendation.dismissals7d >= 0
          && request.resource.data.pricingRecommendation.activeCategoryOffers is int
          && request.resource.data.pricingRecommendation.activeCategoryOffers >= 0
          && request.resource.data.pricingRecommendation.averageDiscountPercent is int
          && request.resource.data.pricingRecommendation.averageDiscountPercent >= 0
          && request.resource.data.pricingRecommendation.averageDiscountPercent <= 100
          && request.resource.data.pricingRecommendation.generatedAt is timestamp
        );
    }

    function isValidProductCreate(productId) {
      return isActiveMerchant()
        && request.resource.data.keys().hasOnly([
          'archivedAt',
          'category',
          'createdAt',
          'deletedAt',
          'discountedPrice',
          'expiresAt',
          'hasImage',
          'hasReservations',
          'imagePath',
          'imageUrl',
          'interestCount',
          'isDeleted',
          'location',
          'merchantName',
          'name',
          'originalPrice',
          'ownerId',
          'pickupEndAt',
          'pickupStartAt',
          'pricingRecommendation',
          'quantity',
          'quantityAvailable',
          'status',
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.merchantName is string
        && request.resource.data.name is string
        && request.resource.data.category is string
        && request.resource.data.originalPrice is int
        && request.resource.data.originalPrice >= 0
        && request.resource.data.discountedPrice is int
        && request.resource.data.discountedPrice >= 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.quantityAvailable is int
        && request.resource.data.quantityAvailable == request.resource.data.quantity
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.pickupStartAt is timestamp
        && request.resource.data.pickupEndAt is timestamp
        && request.resource.data.pickupEndAt > request.resource.data.pickupStartAt
        && request.resource.data.createdAt is timestamp
        && request.resource.data.interestCount == 0
        && request.resource.data.status == 'active'
        && request.resource.data.isDeleted == false
        && request.resource.data.hasReservations == false
        && request.resource.data.archivedAt == null
        && request.resource.data.deletedAt == null
        && hasValidProductImage(productId)
        && hasValidPricingRecommendation();
    }

    function isValidProductOwnerUpdate(productId) {
      return isActiveMerchant()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'archivedAt',
          'category',
          'createdAt',
          'deletedAt',
          'discountedPrice',
          'expiresAt',
          'hasImage',
          'hasReservations',
          'imagePath',
          'imageUrl',
          'interestCount',
          'isDeleted',
          'location',
          'merchantName',
          'name',
          'originalPrice',
          'ownerId',
          'pickupEndAt',
          'pickupStartAt',
          'pricingRecommendation',
          'quantity',
          'quantityAvailable',
          'status',
        ])
        && !(resource.data.hasReservations == true)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.merchantName == resource.data.merchantName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.interestCount == resource.data.interestCount
        && request.resource.data.status == resource.data.status
        && request.resource.data.isDeleted == resource.data.isDeleted
        && request.resource.data.archivedAt == resource.data.archivedAt
        && request.resource.data.deletedAt == resource.data.deletedAt
        && request.resource.data.name is string
        && request.resource.data.category is string
        && request.resource.data.originalPrice is int
        && request.resource.data.originalPrice >= 0
        && request.resource.data.discountedPrice is int
        && request.resource.data.discountedPrice >= 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.quantityAvailable is int
        && request.resource.data.quantityAvailable == request.resource.data.quantity
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.pickupStartAt is timestamp
        && request.resource.data.pickupEndAt is timestamp
        && request.resource.data.pickupEndAt > request.resource.data.pickupStartAt
        && request.resource.data.hasReservations == false
        && hasValidProductImage(productId)
        && hasValidPricingRecommendation();
    }

    match /products/{productId} {
      allow read: if canReadProtectedData();
      allow create: if isValidProductCreate(productId);
      allow update: if isInterestCountUpdate()
        || isValidProductOwnerUpdate(productId);
      allow delete: if false;
    }

    match /reservations/{reservationId} {
      allow create: if false;
      allow read: if isAdmin()
        || (
          isActiveUser()
        && (resource.data.buyerId == request.auth.uid
          || resource.data.merchantId == request.auth.uid)
        );
      allow update: if false;
      allow delete: if false;
    }

    match /merchantStats/{merchantId} {
      allow read: if canReadProtectedData();
      allow create, update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if canReadProtectedData();
      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null
        && request.auth.uid == userId
        && isValidUserCreate();
      allow update: if isValidUserSelfUpdate(userId);
      allow delete: if false;
    }

    match /users/{userId}/adminMessages/{messageId} {
      allow read: if isAdmin()
        || (isActiveUser() && request.auth.uid == userId);
      allow create: if false;
      allow update: if isValidAdminMessageReadUpdate(userId);
      allow delete: if false;
    }

    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if isActiveUser() && request.auth.uid == userId;
    }

    match /interests/{interestId} {
      allow read: if isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || interestId.matches('^' + request.auth.uid + '_.*')
        );
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || interestId.matches('^' + request.auth.uid + '_.*')
        )
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || interestId.matches('^' + request.auth.uid + '_.*')
        );
    }

    match /userInteractions/{interactionId} {
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || (
          isActiveUser()
        && (resource.data.ownerId == request.auth.uid
          || resource.data.userId == request.auth.uid)
        );
    }

    match /userImplicitPrefs/{userId} {
      allow read, write: if isActiveUser() && request.auth.uid == userId;
    }

    match /userNegativePrefs/{userId} {
      allow read, write: if isActiveUser() && request.auth.uid == userId;
    }
  }
}
